  "keyFeatures": [
    "Deterministic gameplay simulation with seeded runs and replay verification",
    "Full implementation of all 5 game modes: Survival, Quest, Rush, Tutorial, and Typ-o-Shooter",
    "Complete weapon and perk system with 58 perks and behavioral parity to original",
    "PAQ archive and JAZ texture extraction with custom format decoders",
    "Headless replay system with differential testing against original binary",
    "Extensive reverse engineering documentation with Ghidra, Frida, and WinDbg evidence",
    "Float32 precision-aware implementation matching original math behavior",
    "High-quality video rendering from replay files at 60fps"
  ],
  "publicApiSurface": [
    "crimson CLI - Main game executable",
    "crimson view - Debug views and sandboxes",
    "crimson extract - PAQ archive extraction",
    "crimson config - Configuration inspection",
    "crimson replay list/play/verify/benchmark/render - Replay management",
    "crimson.gameplay - Core game logic module",
    "crimson.weapons - Weapon system",
    "crimson.perks - Perk implementation and runtime",
    "crimson.replay - Replay recording and playback",
    "grim.paq - PAQ archive format decoder",
    "grim.jaz - JAZ texture format decoder",
    "grim.rand - Deterministic RNG system"
  ]
